{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zoom Explorer",
  "version": "0.1.0",
  "identifier": "is.bios.sym.zoomexplorer",
  "build": {
    "beforeDevCommand": "npm run tauri:serve",
    "devUrl": "http://127.0.0.1:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zoom Explorer",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "targets": "all"
  }
}
